<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head', { title: 'Controle de Armazém - Reaproveitamento' }) %>
</head>

<body>

    <%- include('partials/navbar') %>

        <div class="container page-container my-5">
            <%- include('partials/alerts') %>

                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-header__icon page-header__icon--primary">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <div>
                        <h1 class="page-header__title">Controle de Armazém</h1>
                        <p class="page-header__subtitle">Gerencie as entradas e saídas físicas dos itens doados.</p>
                    </div>
                </div>

                <!-- Tab Navigation -->
                <ul class="nav app-tabs" id="admin-pills-tab" role="tablist">
                    <li class="nav-item flex-fill text-center" role="presentation">
                        <button
                            class="nav-link active w-100"
                            id="pills-entries-tab" data-bs-toggle="pill" data-bs-target="#pills-entries" type="button"
                            role="tab" aria-controls="pills-entries" aria-selected="true">
                            <i class="bi bi-box-arrow-in-down"></i> Entradas Pendentes (Estocagem)
                            <span class="badge bg-danger ms-1">
                                <%= pendingEntries.length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center" role="presentation">
                        <button
                            class="nav-link w-100"
                            id="pills-exits-tab" data-bs-toggle="pill" data-bs-target="#pills-exits" type="button"
                            role="tab" aria-controls="pills-exits" aria-selected="false">
                            <i class="bi bi-box-arrow-up"></i> Saídas Pendentes (Retiradas)
                            <span class="badge bg-warning text-dark ms-1">
                                <%= pendingExits.length %>
                            </span>
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="admin-pills-tabContent">

                    <!-- Pending Entries Tab -->
                    <div class="tab-pane fade show active" id="pills-entries" role="tabpanel"
                        aria-labelledby="pills-entries-tab">
                        <% if (pendingEntries.length===0) { %>
                            <div class="app-card p-5 text-center">
                                <div class="my-3 text-muted">
                                    <i class="bi bi-box-arrow-in-down" style="font-size: 3rem;"></i>
                                </div>
                                <h3 class="h5 fw-bold text-secondary">Nenhuma entrada pendente de estocagem</h3>
                                <p class="text-muted">Todos os produtos cadastrados foram validados e estocados.</p>
                            </div>
                            <% } else { %>
                                <div class="app-card overflow-hidden">
                                    <div class="table-responsive">
                                        <table class="table align-middle table-hover mb-0">
                                            <thead class="table-light text-muted small uppercase fw-bold border-bottom">
                                                <tr>
                                                    <th scope="col" class="ps-4 py-3">Código / Item</th>
                                                    <th scope="col" class="py-3">Categoria</th>
                                                    <th scope="col" class="py-3">Valor</th>
                                                    <th scope="col" class="py-3">Doador</th>
                                                    <th scope="col" class="py-3" style="min-width: 350px;">Avaliação e
                                                        Estocagem</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% pendingEntries.forEach(function(item) { %>
                                                    <tr>
                                                        <!-- Code / Item info -->
                                                        <td class="ps-4 py-3">
                                                            <div class="d-flex align-items-center">
                                                                <img src="<%= item.photo %>"
                                                                    class="item-thumb me-3 shadow-sm border"
                                                                    alt="<%= item.name %>">
                                                                <div>
                                                                    <h6 class="fw-bold mb-1 text-dark">
                                                                        <%= item.name %>
                                                                    </h6>
                                                                    <span class="text-muted small">ID: TKT-<%=
                                                                            item.id.toString().padStart(6, '0' ) %>
                                                                            </span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <!-- Category -->
                                                        <td class="py-3">
                                                            <span class="badge bg-secondary">
                                                                <%= item.category %>
                                                            </span>
                                                        </td>
                                                        <!-- Price -->
                                                        <td class="py-3">
                                                            <span class="fw-bold text-success">R$ <%=
                                                                    parseFloat(item.price).toFixed(2).replace('.', ',' )
                                                                    %></span>
                                                        </td>
                                                        <!-- Donor -->
                                                        <td class="py-3">
                                                            <div class="fw-semibold text-dark">
                                                                <%= item.donor.name %>
                                                            </div>
                                                            <div class="text-muted small" style="font-size: 0.75rem;">
                                                                <%= item.donor.email %>
                                                            </div>
                                                        </td>
                                                        <!-- Action: Condition + Storage Form -->
                                                        <td class="py-3 pe-4">
                                                            <form action="/admin/armazenagem/entrada/<%= item.id %>"
                                                                method="POST" class="d-flex flex-column gap-2">
                                                                <div class="d-flex gap-2">
                                                                    <select name="condition"
                                                                        class="form-select form-select-sm border-secondary-subtle"
                                                                        required>
                                                                        <option value="" disabled selected>Condição...
                                                                        </option>
                                                                        <option value="Perfeito">✅ Perfeito</option>
                                                                        <option value="Bom">👍 Bom</option>
                                                                        <option value="Regular">👌 Regular</option>
                                                                        <option value="Ruim">⚠️ Ruim</option>
                                                                        <option value="Quebrado">❌ Quebrado</option>
                                                                    </select>
                                                                    <input type="text" name="storageCode"
                                                                        class="form-control form-control-sm border-secondary-subtle"
                                                                        placeholder="Ex: A1-S2"
                                                                        pattern="[A-Z]\d+-[A-Z]\d+"
                                                                        title="Deve seguir o formato Letra+Número-Letra+Número (ex: A1-S2, F12-B09)"
                                                                        required>
                                                                </div>
                                                                <button type="submit"
                                                                    class="btn btn-success btn-sm fw-bold px-3 shadow-sm text-nowrap w-100">
                                                                    <i class="bi bi-clipboard-check me-1"></i>Avaliar e
                                                                    Estocar
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>
                    </div>

                    <!-- Pending Exits Tab -->
                    <div class="tab-pane fade" id="pills-exits" role="tabpanel" aria-labelledby="pills-exits-tab">
                        <% if (pendingExits.length===0) { %>
                            <div class="app-card p-5 text-center">
                                <div class="my-3 text-muted">
                                    <i class="bi bi-box-arrow-up" style="font-size: 3rem;"></i>
                                </div>
                                <h3 class="h5 fw-bold text-secondary">Nenhuma saída pendente de entrega</h3>
                                <p class="text-muted">Não há itens aguardando retirada física no momento.</p>
                            </div>
                            <% } else { %>
                                <div class="app-card overflow-hidden">
                                    <div class="table-responsive">
                                        <table class="table align-middle table-hover mb-0">
                                            <thead class="table-light text-muted small uppercase fw-bold border-bottom">
                                                <tr>
                                                    <th scope="col" class="ps-4 py-3">Código Ticket / Item</th>
                                                    <th scope="col" class="py-3">Valor</th>
                                                    <th scope="col" class="py-3">Local no Armazém</th>
                                                    <th scope="col" class="py-3">Recebedor</th>
                                                    <th scope="col" class="py-3 text-end pe-4">Ação</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% pendingExits.forEach(function(item) { %>
                                                    <tr>
                                                        <!-- Code / Item info -->
                                                        <td class="ps-4 py-3">
                                                            <div class="d-flex align-items-center">
                                                                <img src="<%= item.photo %>"
                                                                    class="item-thumb me-3 shadow-sm border"
                                                                    alt="<%= item.name %>">
                                                                <div>
                                                                    <h6 class="fw-bold mb-1 text-dark">
                                                                        <%= item.name %>
                                                                    </h6>
                                                                    <strong class="text-primary font-monospace">TKT-<%=
                                                                            item.id.toString().padStart(6, '0' ) %>
                                                                            </strong>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <!-- Price -->
                                                        <td class="py-3">
                                                            <span class="fw-bold text-success">R$ <%=
                                                                    parseFloat(item.price).toFixed(2).replace('.', ',' )
                                                                    %></span>
                                                        </td>
                                                        <!-- Storage Location -->
                                                        <td class="py-3">
                                                            <span
                                                                class="badge bg-warning text-dark fs-6 p-2 px-3 border border-warning border-opacity-25">
                                                                <i class="bi bi-geo-alt-fill me-1"></i>
                                                                <%= item.storageCode || 'A definir' %>
                                                            </span>
                                                        </td>
                                                        <!-- Receiver -->
                                                        <td class="py-3">
                                                            <div class="fw-semibold text-dark">
                                                                <%= item.receiver.name %>
                                                            </div>
                                                            <div class="text-muted small" style="font-size: 0.75rem;">
                                                                <%= item.receiver.email %>
                                                            </div>
                                                        </td>
                                                        <!-- Action Exit Confirmation button -->
                                                        <td class="py-3 text-end pe-4">
                                                            <form action="/admin/armazenagem/saida/<%= item.id %>"
                                                                method="POST">
                                                                <button type="submit"
                                                                    class="btn btn-primary btn-sm fw-bold shadow-sm">
                                                                    <i class="bi bi-box2-fill me-1"></i>Confirmar
                                                                    Entrega
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>
                    </div>

                </div>
        </div>

        <%- include('partials/footer') %>

            <script src="/js/adminArmazenagem.js" defer></script>
</body>

</html>