<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head', { title: 'Doações Disponíveis - Reaproveitamento' }) %>
</head>

<body>

    <%- include('partials/navbar') %>

        <div class="container page-container my-5">
            <%- include('partials/alerts') %>

                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-header__icon page-header__icon--primary">
                        <i class="bi bi-box2-heart"></i>
                    </div>
                    <div>
                        <h1 class="page-header__title">Doações Disponíveis</h1>
                        <p class="page-header__subtitle">Encontre itens disponíveis e resgate com seus créditos.</p>
                    </div>
                </div>


                <!-- Search and Filters Section -->
                <div class="app-card mb-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3"><i class="bi bi-funnel me-2"></i>Buscar e Filtrar Doações</h2>
                        <form action="/doacoes" method="GET" class="row g-3">
                            <!-- Search Input -->
                            <div class="col-md-6">
                                <label for="searchName" class="form-label small fw-semibold text-muted">Nome do
                                    Item</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted border-end-0"><i
                                            class="bi bi-search"></i></span>
                                    <input type="text" class="form-control border-start-0 bg-light bg-opacity-50"
                                        id="searchName" name="name" value="<%= filters.name %>"
                                        placeholder="Digite o nome do item...">
                                </div>
                            </div>

                            <!-- Category Dropdown -->
                            <div class="col-md-4">
                                <label for="filterCategory" class="form-label small fw-semibold text-muted">Filtrar por
                                    Categoria</label>
                                <select class="form-select bg-light bg-opacity-50" id="filterCategory" name="category">
                                    <option value="">Todas as Categorias</option>
                                    <option value="Eletrônicos" <%=filters.category==='Eletrônicos' ? 'selected' : '' %>
                                        >Eletrônicos</option>
                                    <option value="Roupas" <%=filters.category==='Roupas' ? 'selected' : '' %>>Roupas
                                    </option>
                                    <option value="Livros" <%=filters.category==='Livros' ? 'selected' : '' %>>Livros
                                    </option>
                                    <option value="Móveis" <%=filters.category==='Móveis' ? 'selected' : '' %>>Móveis
                                    </option>
                                    <option value="Outros" <%=filters.category==='Outros' ? 'selected' : '' %>>Outros
                                    </option>
                                </select>
                            </div>

                            <!-- Filter Actions Buttons -->
                            <div class="col-md-2 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary w-100 fw-semibold shadow-sm"><i
                                        class="bi bi-funnel-fill me-1"></i>Filtrar</button>
                                <% if (filters.category || filters.name) { %>
                                    <a href="/doacoes" class="btn btn-outline-secondary px-3" title="Limpar Filtros"><i
                                            class="bi bi-trash"></i></a>
                                    <% } %>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Donations Grid -->
                <h2 class="h4 fw-bold mb-4"><i class="bi bi-card-list me-2"></i>Itens Disponíveis</h2>

                <% if (donations.length===0) { %>
                    <div class="app-card p-5 text-center">
                        <div class="my-4">
                            <i class="bi bi-box2 text-muted" style="font-size: 4rem;"></i>
                        </div>
                        <h3 class="h5 fw-bold text-secondary">Nenhuma doação disponível no momento</h3>
                        <p class="text-muted">Experimente alterar os filtros de busca ou seja o primeiro a <a
                                href="/doacoes/nova" class="text-success fw-bold text-decoration-none">cadastrar um
                                item</a>!</p>
                    </div>
                    <% } else { %>
                        <div class="row g-4">
                            <% donations.forEach(function(item) { %>
                                <div class="col-md-4 col-sm-6">
                                    <div
                                        class="app-card h-100 donation-card">
                                        <!-- Image Container -->
                                        <div class="img-container">
                                            <span class="badge bg-dark category-badge shadow-sm">
                                                <%= item.category %>
                                            </span>
                                            <% if (item.condition) { %>
                                                <% const condColors={ 'Perfeito' : 'success' , 'Bom' : 'primary'
                                                    , 'Regular' : 'warning text-dark' , 'Ruim' : 'orange' , 'Quebrado'
                                                    : 'danger' }; %>
                                                    <span
                                                        class="badge bg-<%= condColors[item.condition] || 'secondary' %> shadow-sm"
                                                        style="position: absolute; top: 10px; left: 10px; z-index: 10;">
                                                        <i class="bi bi-clipboard-check me-1"></i>
                                                        <%= item.condition %>
                                                    </span>
                                                    <% } %>
                                                        <img src="<%= item.photo %>" alt="<%= item.name %>">
                                        </div>

                                        <!-- Card Body -->
                                        <div class="card-body p-4 d-flex flex-column">
                                            <h3 class="h5 fw-bold card-title mb-2 text-dark text-truncate"
                                                title="<%= item.name %>">
                                                <%= item.name %>
                                            </h3>
                                            <p class="text-muted small card-text mb-3 flex-grow-1"
                                                style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                                <%= item.description %>
                                            </p>

                                            <div class="border-top pt-3 mt-auto">
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <div>
                                                        <span class="text-muted small d-block">Doador(a)</span>
                                                        <span class="fw-semibold text-dark text-truncate d-inline-block"
                                                            style="max-width: 150px;">
                                                            <%= item.donor.name %>
                                                        </span>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="text-muted small d-block">Valor</span>
                                                        <span class="h5 fw-bold text-success m-0">R$ <%=
                                                                parseFloat(item.price).toFixed(2).replace('.', ',' ) %>
                                                                </span>
                                                    </div>
                                                </div>

                                                <!-- Action Button -->
                                                <% if (item.userId===user.id) { %>
                                                    <button class="btn btn-outline-secondary w-100 fw-bold rounded-3"
                                                        disabled>
                                                        <i class="bi bi-person-check me-2"></i>Seu Item
                                                    </button>
                                                    <% } else if (user.admin) { %>
                                                        <button
                                                            class="btn btn-outline-secondary w-100 fw-bold rounded-3"
                                                            disabled>
                                                            <i class="bi bi-eye me-2"></i>Somente Visualização
                                                        </button>
                                                        <% } else { %>
                                                            <button
                                                                class="btn btn-success w-100 fw-bold rounded-3 shadow-sm hover-btn"
                                                                data-bs-toggle="modal" data-bs-target="#claimModal"
                                                                data-id="<%= item.id %>" data-name="<%= item.name %>"
                                                                data-price="<%= item.price %>"
                                                                data-category="<%= item.category %>">
                                                                <i class="bi bi-cart-plus me-2"></i>Receber Doação
                                                            </button>
                                                            <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } %>
        </div>

        <!-- Claim Confirmation Modal -->
        <div class="modal fade" id="claimModal" tabindex="-1" aria-labelledby="claimModalLabel" aria-hidden="true" data-user-credits="<%= user.credits %>">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
                    <div class="modal-header bg-dark text-white p-3 border-0">
                        <h5 class="modal-title fw-bold" id="claimModalLabel"><i
                                class="bi bi-question-circle text-success me-2"></i>Confirmar Recebimento</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body p-4 bg-white">
                        <p class="text-muted">Você está prestes a resgatar o seguinte item do sistema utilizando seus
                            créditos:</p>

                        <!-- Item Box Info -->
                        <div class="p-3 bg-light rounded-3 mb-3 border">
                            <div class="row">
                                <div class="col-8">
                                    <h6 class="fw-bold mb-1 text-dark" id="modalItemName">---</h6>
                                    <span class="badge bg-secondary mb-0" id="modalItemCategory">---</span>
                                </div>
                                <div class="col-4 text-end">
                                    <span class="text-muted small d-block">Preço</span>
                                    <span class="fw-bold text-success" id="modalItemPrice">R$ 0,00</span>
                                </div>
                            </div>
                        </div>

                        <!-- User Credits Info -->
                        <div class="d-flex justify-content-between align-items-center mb-4 p-2">
                            <span class="text-muted">Seu saldo atual de créditos:</span>
                            <span class="fw-bold text-dark fs-5" id="userCreditsDisplay">R$ <%=
                                    parseFloat(user.credits).toFixed(2).replace('.', ',' ) %></span>
                        </div>

                        <!-- Danger Insufficient Balance Warning -->
                        <div id="insufficientBalanceAlert" class="alert alert-danger border-0 rounded-3 mb-0"
                            style="display: none;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Saldo Insuficiente!</strong> Você não possui créditos suficientes para resgatar este
                            item.
                        </div>
                    </div>

                    <div class="modal-footer bg-light p-3 border-0">
                        <button type="button" class="btn btn-outline-secondary px-3"
                            data-bs-dismiss="modal">Cancelar</button>
                        <form id="claimForm" method="POST" action="">
                            <button type="submit" id="confirmClaimBtn"
                                class="btn btn-success px-4 fw-bold shadow-sm">Confirmar Resgate</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="/js/doacoes.js" defer></script>
</body>

</html>