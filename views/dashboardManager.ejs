<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <title>Dashboard Manager</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h3 class="card-title mb-4">Dashboard</h3>
                            <p>Bem-vindo ao seu dashboard!</p>
                            <h4 class="mt-4">Informações do administrador:</h4>
                            <ul class="list-group">
                                <li class="list-group-item"><strong>Nome:</strong> <%= user.name %></li>
                                <li class="list-group-item"><strong>Email:</strong> <%= user.email %></li>
                            </ul>
                            <% if (canCreateAdmin) { %>
                                <form action="/cadastro" method="GET" class="mt-3">
                                    <button type="submit" class="btn btn-outline-primary w-100">Criar novo administrador</button>
                                </form>
                            <% } %>
                            
                            <div class="mt-4 d-grid gap-2">
                                <a href="/veiculos/registro" class="btn btn-success">Gerenciar Entrada / Saída</a>
                            </div>

                            <h4 class="mt-4">Configuração:</h4>
                            <%- include('partials/flashMessages') %>
                            <form action="/dashboard/capacidade" method="POST" id="capacidadeForm">
                                <label for="capacidadeTotal" class="form-label">Total de vagas</label>
                                <div class="input-group mb-3">
                                    <input
                                        type="number"
                                        class="form-control"
                                        id="capacidadeTotal"
                                        name="capacidadeTotal"
                                        value="<%= estacionamento.capacidadeTotal %>"
                                        min="<%= Math.max(1, estacionamento.vagasOcupadas) %>"
                                        step="1"
                                        readonly
                                    >
                                    <button class="btn btn-primary" type="button" id="editarCapacidade">Editar</button>
                                </div>
                            </form>
                            <h4 class="mt-4">Estacionamento:</h4>
                            <ul class="list-group">
                                <li class="list-group-item"><strong>Vagas disponíveis:</strong> <%= estacionamento.vagasDisponiveis %></li>
                                <li class="list-group-item"><strong>Ocupação:</strong> <%= estacionamento.porcentagemOcupacao %>%</li>
                            </ul>
                            <div class="progress mt-3" role="progressbar" aria-valuenow="<%= estacionamento.porcentagemOcupacao %>" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width: <%= estacionamento.porcentagemOcupacao %>%"></div>
                            </div>
                        </div>
                        <div class="card-body">
                            <form action="/logout" method="POST">
                                <button type="submit" class="btn btn-danger">Sair</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script src="/dashboardManager.js"></script>
    </body>
</html>
