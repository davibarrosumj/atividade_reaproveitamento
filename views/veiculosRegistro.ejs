<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <title>Registro de Veículos</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title mb-4">Registro de Entrada / Saída de Veículos</h3>
                            
                            <%- include('partials/flashMessages') %>

                            <!-- Formulário de Entrada -->
                            <form action="/veiculos/registro/entrada" method="POST" class="mb-5">
                                <h5 class="card-subtitle mb-3 text-muted">Registrar Entrada</h5>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-8">
                                        <label for="placa" class="form-label">Placa do Veículo (ex: ABC-1234 ou ABC1D23):</label>
                                        <input 
                                            type="text" 
                                            class="form-control text-uppercase" 
                                            id="placa" 
                                            name="placa" 
                                            placeholder="Digite a placa" 
                                            required
                                        >
                                    </div>
                                    <div class="col-md-4">
                                        <button type="submit" class="btn btn-success w-100">Registrar Entrada</button>
                                    </div>
                                </div>
                            </form>

                            <!-- Tabela de Veículos Estacionados -->
                            <h5 class="card-subtitle mb-3 text-muted">Veículos Estacionados (Vagas Ocupadas)</h5>
                            <% if (registrosAtivos.length === 0) { %>
                                <div class="alert alert-info" role="alert">
                                    Não há veículos estacionados no momento.
                                </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Placa</th>
                                                <th>Horário de Entrada</th>
                                                <th class="text-end">Ações</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% registrosAtivos.forEach((registro) => { %>
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-secondary fs-6"><%= registro.placa %></span>
                                                    </td>
                                                    <td>
                                                        <%= new Date(registro.horarioEntrada).toLocaleString('pt-BR') %>
                                                    </td>
                                                    <td class="text-end">
                                                        <form action="/veiculos/registro/saida/<%= registro.id %>" method="POST" style="display: inline;">
                                                            <button type="submit" class="btn btn-danger btn-sm">Registrar Saída</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                        <div class="card-footer bg-white py-3">
                            <a href="/dashboard" class="btn btn-secondary">Voltar para o Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
