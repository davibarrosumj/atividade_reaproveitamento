<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('partials/head', { title: 'Erro - Reaproveitamento' }) %>
</head>
<body class="vh-100 d-flex align-items-center justify-content-center">

    <div class="error-card p-3">
        <div class="app-card text-center">
            <div class="card-body p-5">
                <div class="mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-danger bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg>
                </div>
                
                <h1 class="h3 mb-3 fw-bold">Algo deu errado</h1>
                <p class="text-muted mb-4"><%= message %></p>

                <% if (error && error.stack) { %>
                    <div class="text-start mb-4">
                        <label class="form-label fw-bold text-muted small">Detalhes técnicos (Modo de Desenvolvimento):</label>
                        <pre class="bg-dark text-light p-3 rounded small overflow-auto" style="max-height: 250px;"><%= error.stack %></pre>
                    </div>
                <% } %>

                <a href="/" id="backHomeBtn" class="btn btn-primary px-4 py-2">Voltar para o Início</a>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
