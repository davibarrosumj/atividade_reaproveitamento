<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <title>Configurações do Estacionamento</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title mb-4">Configurações Gerais</h3>
                            
                            <%- include('partials/flashMessages') %>

                            <form action="/dashboard/config" method="POST">
                                <h5 class="text-muted border-bottom pb-2 mb-3">Capacidade de Vagas</h5>
                                <div class="row mb-4">
                                    <div class="col-md-6 mb-3">
                                        <label for="capacidadeCarros" class="form-label">Capacidade Máxima de Carros:</label>
                                        <input 
                                            type="number" 
                                            class="form-control" 
                                            id="capacidadeCarros" 
                                            name="capacidadeCarros" 
                                            value="<%= estacionamento.capacidadeCarros %>" 
                                            min="<%= Math.max(1, estacionamento.vagasOcupadasCarros) %>" 
                                            required
                                        >
                                        <div class="form-text">Mínimo aceito: atual ocupação de carros (<%= estacionamento.vagasOcupadasCarros %>).</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="capacidadeMotos" class="form-label">Capacidade Máxima de Motos:</label>
                                        <input 
                                            type="number" 
                                            class="form-control" 
                                            id="capacidadeMotos" 
                                            name="capacidadeMotos" 
                                            value="<%= estacionamento.capacidadeMotos %>" 
                                            min="<%= Math.max(1, estacionamento.vagasOcupadasMotos) %>" 
                                            required
                                        >
                                        <div class="form-text">Mínimo aceito: atual ocupação de motos (<%= estacionamento.vagasOcupadasMotos %>).</div>
                                    </div>
                                </div>

                                <h5 class="text-muted border-bottom pb-2 mb-3">Valores dos Tíquetes</h5>
                                <div class="row mb-4">
                                    <div class="col-md-6 mb-3">
                                        <label for="valorTiqueteCarro" class="form-label">Tarifa de Carros (R$):</label>
                                        <input 
                                            type="number" 
                                            step="0.01" 
                                            class="form-control" 
                                            id="valorTiqueteCarro" 
                                            name="valorTiqueteCarro" 
                                            value="<%= Number(estacionamento.valorTiqueteCarro).toFixed(2) %>" 
                                            min="0.01" 
                                            required
                                        >
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="valorTiqueteMoto" class="form-label">Tarifa de Motos (R$):</label>
                                        <input 
                                            type="number" 
                                            step="0.01" 
                                            class="form-control" 
                                            id="valorTiqueteMoto" 
                                            name="valorTiqueteMoto" 
                                            value="<%= Number(estacionamento.valorTiqueteMoto).toFixed(2) %>" 
                                            min="0.01" 
                                            required
                                        >
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-4">
                                    <a href="/dashboard" class="btn btn-secondary">Voltar</a>
                                    <button type="submit" class="btn btn-primary px-4">Salvar Configurações</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
