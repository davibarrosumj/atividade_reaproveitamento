<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('partials/head', { title: 'Cadastro - Reaproveitamento' }) %>
</head>
<body class="vh-100 d-flex align-items-center justify-content-center">

    <div class="register-card p-3">
        <%- include('partials/alerts') %>

        <div class="app-card">
            <div class="card-body p-4">
                <h1 class="h3 mb-3 text-center fw-bold">Criar Conta</h1>
                <p class="text-muted text-center mb-4">Cadastre-se para acessar o painel</p>

                <form id="registerForm" action="/register" method="post">
                    <div class="mb-3">
                        <label for="registerName" class="form-label">Nome Completo</label>
                        <input type="text" class="form-control" id="registerName" name="name" placeholder="Seu nome" required>
                    </div>
                    <div class="mb-3">
                        <label for="registerEmail" class="form-label">E-mail</label>
                        <input type="email" class="form-control" id="registerEmail" name="email" placeholder="nome@exemplo.com" required>
                    </div>
                    <div class="mb-3">
                        <label for="registerPassword" class="form-label">Senha</label>
                        <input type="password" class="form-control" id="registerPassword" name="password" placeholder="Mínimo 8 caracteres, com Maiúscula, Minúscula e Número" required>
                    </div>
                    <div class="mb-3">
                        <label for="registerConfirmPassword" class="form-label">Confirmar Senha</label>
                        <input type="password" class="form-control" id="registerConfirmPassword" name="confirmPassword" placeholder="Confirme sua senha" required>
                    </div>
                    <button type="submit" id="registerSubmitBtn" class="btn btn-primary w-100 py-2 mt-2">Cadastrar</button>
                </form>

                <hr class="my-4">

                <div class="text-center">
                    <span class="text-muted">Já tem uma conta?</span>
                    <a href="/" id="goToLoginLink" class="text-decoration-none ms-1">Faça login</a>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
