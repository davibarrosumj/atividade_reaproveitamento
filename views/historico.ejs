<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head', { title: 'Meu Histórico - Reaproveitamento' }) %>
</head>

<body>

    <%- include('partials/navbar') %>

        <div class="container page-container my-5">
            <%- include('partials/alerts') %>

                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-header__icon page-header__icon--primary">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <h1 class="page-header__title">Histórico de Movimentações</h1>
                        <p class="page-header__subtitle">Gerencie e acompanhe seus itens cadastrados para doação e os itens que você resgatou.</p>
                    </div>
                </div>

                <!-- Tab Navigation -->
                <ul class="nav app-tabs" id="pills-tab" role="tablist">
                    <li class="nav-item flex-fill text-center" role="presentation">
                        <button
                            class="nav-link active w-100"
                            id="pills-offered-tab" data-bs-toggle="pill" data-bs-target="#pills-offered" type="button"
                            role="tab" aria-controls="pills-offered" aria-selected="true">
                            <i class="bi bi-gift-fill"></i> Minhas Doações Oferecidas
                            <span class="badge bg-secondary ms-1">
                                <%= offeredItems.length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center" role="presentation">
                        <button
                            class="nav-link w-100"
                            id="pills-received-tab" data-bs-toggle="pill" data-bs-target="#pills-received" type="button"
                            role="tab" aria-controls="pills-received" aria-selected="false">
                            <i class="bi bi-bag-heart-fill"></i> Itens Recebidos
                            <span class="badge bg-secondary ms-1">
                                <%= receivedItems.length %>
                            </span>
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="pills-tabContent">
                    <!-- Offered Items Tab -->
                    <div class="tab-pane fade show active" id="pills-offered" role="tabpanel"
                        aria-labelledby="pills-offered-tab">
                        <% if (offeredItems.length===0) { %>
                            <div class="app-card p-5 text-center">
                                <div class="my-3 text-muted">
                                    <i class="bi bi-gift" style="font-size: 3rem;"></i>
                                </div>
                                <h3 class="h5 fw-bold text-secondary">Você ainda não ofereceu nenhum item</h3>
                                <p class="text-muted mb-3">Compartilhe algo que você não usa mais com outras pessoas.
                                </p>
                                <div>
                                    <a href="/doacoes/nova" class="btn btn-success fw-bold px-4 shadow-sm"><i
                                            class="bi bi-plus-circle me-2"></i>Oferecer Item</a>
                                </div>
                            </div>
                            <% } else { %>
                                <div class="app-card overflow-hidden">
                                    <div class="table-responsive">
                                        <table class="table align-middle table-hover mb-0">
                                            <thead class="table-light text-muted small uppercase fw-bold border-bottom">
                                                <tr>
                                                    <th scope="col" class="ps-4 py-3">Item</th>
                                                    <th scope="col" class="py-3">Categoria</th>
                                                    <th scope="col" class="py-3">Valor</th>
                                                    <th scope="col" class="py-3">Data de Cadastro</th>
                                                    <th scope="col" class="py-3">Status / Recebedor</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% offeredItems.forEach(function(item) { %>
                                                    <tr>
                                                        <!-- Item info -->
                                                        <td class="ps-4 py-3">
                                                            <div class="d-flex align-items-center">
                                                                <img src="<%= item.photo %>"
                                                                    class="item-thumb me-3 shadow-sm border"
                                                                    alt="<%= item.name %>">
                                                                <div>
                                                                    <h6 class="fw-bold mb-1 text-dark">
                                                                        <%= item.name %>
                                                                    </h6>
                                                                    <p class="text-muted mb-0 small text-truncate"
                                                                        style="max-width: 250px;">
                                                                        <%= item.description %>
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <!-- Category -->
                                                        <td class="py-3">
                                                            <span class="badge bg-secondary">
                                                                <%= item.category %>
                                                            </span>
                                                        </td>
                                                        <!-- Value -->
                                                        <td class="py-3">
                                                            <span class="fw-bold text-success">R$ <%=
                                                                    parseFloat(item.price).toFixed(2).replace('.', ',' )
                                                                    %></span>
                                                        </td>
                                                        <!-- Date -->
                                                        <td class="py-3 text-muted small">
                                                            <%= new Date(item.createdAt).toLocaleDateString('pt-BR', {
                                                                day: '2-digit' , month: '2-digit' , year: 'numeric' ,
                                                                hour: '2-digit' , minute:'2-digit' }) %>
                                                        </td>
                                                        <!-- Status -->
                                                        <td class="py-3">
                                                            <% // Helper: condition → badge color const
                                                                conditionColors={ 'Perfeito' : 'success' , 'Bom'
                                                                : 'primary' , 'Regular' : 'warning text-dark' , 'Ruim'
                                                                : 'orange' , 'Quebrado' : 'danger' }; %>
                                                                <% if (item.status==='registered' ) { %>
                                                                    <span
                                                                        class="badge bg-secondary mb-1 d-inline-block"><i
                                                                            class="bi bi-clock me-1"></i>Aguardando
                                                                        Entrada no Armazém</span>
                                                                    <% } else if (item.status==='triaged' ) { %>
                                                                        <span
                                                                            class="badge bg-info text-white mb-2 d-inline-block"><i
                                                                                class="bi bi-clipboard-check me-1"></i>Triagem
                                                                            Concluída</span>
                                                                        <div class="mb-2">
                                                                            <span
                                                                                class="text-muted small d-block">Condição
                                                                                avaliada:</span>
                                                                            <span
                                                                                class="badge bg-<%= conditionColors[item.condition] || 'secondary' %> fs-6 px-3 py-1">
                                                                                <%= item.condition %>
                                                                            </span>
                                                                        </div>
                                                                        <% if (item.storageCode) { %>
                                                                            <div class="small text-muted mb-2">Estoque:
                                                                                <strong>
                                                                                    <%= item.storageCode %>
                                                                                </strong></div>
                                                                            <% } %>
                                                                                <div class="d-flex gap-2 mt-1">
                                                                                    <form
                                                                                        action="/doacoes/confirmar-triagem/<%= item.id %>"
                                                                                        method="POST">
                                                                                        <button type="submit"
                                                                                            class="btn btn-success btn-sm fw-bold shadow-sm">
                                                                                            <i
                                                                                                class="bi bi-check-circle me-1"></i>Confirmar
                                                                                        </button>
                                                                                    </form>
                                                                                    <form
                                                                                        action="/doacoes/cancelar-triagem/<%= item.id %>"
                                                                                        method="POST"
                                                                                        onsubmit="return confirm('Tem certeza que deseja cancelar esta doação? O item precisará ser retirado no armazém.');">
                                                                                        <button type="submit"
                                                                                            class="btn btn-outline-danger btn-sm fw-bold">
                                                                                            <i
                                                                                                class="bi bi-x-circle me-1"></i>Cancelar
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                                <% } else if (item.status==='available'
                                                                                    ) { %>
                                                                                    <span
                                                                                        class="badge bg-success mb-1 d-inline-block"><i
                                                                                            class="bi bi-check2-circle me-1"></i>Disponível
                                                                                        na Listagem</span>
                                                                                    <% if (item.condition) { %>
                                                                                        <div class="small text-muted">
                                                                                            Condição: <span
                                                                                                class="badge bg-<%= conditionColors[item.condition] || 'secondary' %> small">
                                                                                                <%= item.condition %>
                                                                                            </span></div>
                                                                                        <% } %>
                                                                                            <% if (item.storageCode) {
                                                                                                %>
                                                                                                <div
                                                                                                    class="small text-muted">
                                                                                                    Estoque: <strong>
                                                                                                        <%= item.storageCode
                                                                                                            %>
                                                                                                    </strong></div>
                                                                                                <% } %>
                                                                                                    <% } else if
                                                                                                        (item.status==='pending'
                                                                                                        ) { %>
                                                                                                        <span
                                                                                                            class="badge bg-warning text-dark mb-1 d-inline-block"><i
                                                                                                                class="bi bi-hourglass-split me-1"></i>Aguardando
                                                                                                            Retirada
                                                                                                            Física</span>
                                                                                                        <div
                                                                                                            class="small text-muted">
                                                                                                            Por:
                                                                                                            <strong>
                                                                                                                <%= item.receiver.name
                                                                                                                    %>
                                                                                                            </strong>
                                                                                                            <% if
                                                                                                                (item.storageCode)
                                                                                                                { %>
                                                                                                                <div class="small text-muted"
                                                                                                                    style="font-size: 0.75rem;">
                                                                                                                    Estoque:
                                                                                                                    <%= item.storageCode
                                                                                                                        %>
                                                                                                                </div>
                                                                                                                <% } %>
                                                                                                        </div>
                                                                                                        <% } else if
                                                                                                            (item.status==='collected'
                                                                                                            ) { %>
                                                                                                            <span
                                                                                                                class="badge bg-info text-white mb-1 d-inline-block"><i
                                                                                                                    class="bi bi-bag-check me-1"></i>Entregue</span>
                                                                                                            <div
                                                                                                                class="small text-muted">
                                                                                                                Para:
                                                                                                                <strong>
                                                                                                                    <%= item.receiver.name
                                                                                                                        %>
                                                                                                                </strong>
                                                                                                            </div>
                                                                                                            <% } else if
                                                                                                                (item.status==='cancelled'
                                                                                                                ) { %>
                                                                                                                <span
                                                                                                                    class="badge bg-dark mb-1 d-inline-block"><i
                                                                                                                        class="bi bi-x-lg me-1"></i>Cancelada</span>
                                                                                                                <% if
                                                                                                                    (item.condition)
                                                                                                                    { %>
                                                                                                                    <div
                                                                                                                        class="small text-muted">
                                                                                                                        Condição
                                                                                                                        avaliada:
                                                                                                                        <span
                                                                                                                            class="badge bg-<%= conditionColors[item.condition] || 'secondary' %> small">
                                                                                                                            <%= item.condition
                                                                                                                                %>
                                                                                                                        </span>
                                                                                                                    </div>
                                                                                                                    <% }
                                                                                                                        %>
                                                                                                                        <% }
                                                                                                                            %>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>
                    </div>

                    <!-- Received Items Tab -->
                    <div class="tab-pane fade" id="pills-received" role="tabpanel" aria-labelledby="pills-received-tab">
                        <% if (receivedItems.length===0) { %>
                            <div class="app-card p-5 text-center">
                                <div class="my-3 text-muted">
                                    <i class="bi bi-bag-heart" style="font-size: 3rem;"></i>
                                </div>
                                <h3 class="h5 fw-bold text-secondary">Você ainda não recebeu nenhum item</h3>
                                <p class="text-muted mb-3">Dê uma olhada nos itens disponíveis e utilize seus créditos
                                    para resgatá-los!</p>
                                <div>
                                    <a href="/doacoes" class="btn btn-primary fw-bold px-4 shadow-sm"><i
                                            class="bi bi-search me-2"></i>Ver Itens Disponíveis</a>
                                </div>
                            </div>
                            <% } else { %>
                                <div class="app-card overflow-hidden">
                                    <div class="table-responsive">
                                        <table class="table align-middle table-hover mb-0">
                                            <thead class="table-light text-muted small uppercase fw-bold border-bottom">
                                                <tr>
                                                    <th scope="col" class="ps-4 py-3">Item</th>
                                                    <th scope="col" class="py-3">Categoria</th>
                                                    <th scope="col" class="py-3">Valor Gasto</th>
                                                    <th scope="col" class="py-3">Data do Resgate</th>
                                                    <th scope="col" class="py-3">Doador Original</th>
                                                    <th scope="col" class="py-3">Status / Ação</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% receivedItems.forEach(function(item) { %>
                                                    <tr>
                                                        <!-- Item info -->
                                                        <td class="ps-4 py-3">
                                                            <div class="d-flex align-items-center">
                                                                <img src="<%= item.photo %>"
                                                                    class="item-thumb me-3 shadow-sm border"
                                                                    alt="<%= item.name %>">
                                                                <div>
                                                                    <h6 class="fw-bold mb-1 text-dark">
                                                                        <%= item.name %>
                                                                    </h6>
                                                                    <p class="text-muted mb-0 small text-truncate"
                                                                        style="max-width: 250px;">
                                                                        <%= item.description %>
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <!-- Category -->
                                                        <td class="py-3">
                                                            <span class="badge bg-secondary">
                                                                <%= item.category %>
                                                            </span>
                                                        </td>
                                                        <!-- Price -->
                                                        <td class="py-3">
                                                            <span class="fw-bold text-danger">- R$ <%=
                                                                    parseFloat(item.price).toFixed(2).replace('.', ',' )
                                                                    %></span>
                                                        </td>
                                                        <!-- Claim date -->
                                                        <td class="py-3 text-muted small">
                                                            <%= new Date(item.updatedAt).toLocaleDateString('pt-BR', {
                                                                day: '2-digit' , month: '2-digit' , year: 'numeric' ,
                                                                hour: '2-digit' , minute:'2-digit' }) %>
                                                        </td>
                                                        <!-- Donor info -->
                                                        <td class="py-3">
                                                            <div class="fw-semibold text-dark">
                                                                <%= item.donor.name %>
                                                            </div>
                                                            <div class="text-muted small" style="font-size: 0.75rem;">
                                                                <%= item.donor.email %>
                                                            </div>
                                                        </td>
                                                        <!-- Status / Ação -->
                                                        <td class="py-3">
                                                            <% if (item.status==='pending' ) { %>
                                                                <span
                                                                    class="badge bg-danger text-white mb-2 d-inline-block"><i
                                                                        class="bi bi-hourglass-split me-1"></i>Não
                                                                    Recebido</span>
                                                                <button
                                                                    class="btn btn-primary btn-sm d-block fw-bold shadow-sm"
                                                                    data-bs-toggle="modal" data-bs-target="#ticketModal"
                                                                    data-id="<%= item.id %>"
                                                                    data-name="<%= item.name %>"
                                                                    data-category="<%= item.category %>"
                                                                    data-price="<%= item.price %>"
                                                                    data-storage="<%= item.storageCode %>"
                                                                    data-date="<%= new Date(item.updatedAt).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute:'2-digit' }) %>">
                                                                    <i class="bi bi-ticket-perforated me-1"></i>Ver
                                                                    Ticket
                                                                </button>
                                                                <% } else if (item.status==='collected' ) { %>
                                                                    <span class="badge bg-success text-white"><i
                                                                            class="bi bi-check2-all me-1"></i>Recebido /
                                                                        Retirado</span>
                                                                    <% } %>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>
                    </div>
                </div>
        </div>

        <!-- Ticket Modal -->
        <div class="modal fade" id="ticketModal" tabindex="-1" aria-labelledby="ticketModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
                    <div class="modal-header bg-dark text-white p-3 border-0">
                        <h5 class="modal-title fw-bold" id="ticketModalLabel"><i
                                class="bi bi-ticket-perforated text-warning me-2"></i>Ticket de Retirada Física</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body p-4 bg-white">
                        <p class="text-muted small text-center mb-3">Apresente este ticket ao administrador local no
                            armazém físico para retirar seu item.</p>

                        <!-- Ticket Design Card -->
                        <div
                            class="card border-2 border-dashed border-primary rounded-4 bg-light overflow-hidden shadow-sm">
                            <div class="card-body p-4 text-center">
                                <div class="text-muted small uppercase fw-bold mb-1">Código do Ticket</div>
                                <h4 class="fw-bold text-primary mb-3" id="tktCode">TKT-000000</h4>
                                <hr class="border-secondary border-opacity-25 my-3">

                                <div class="row text-start g-3">
                                    <div class="col-6">
                                        <span class="text-muted small d-block">Item</span>
                                        <strong class="text-dark" id="tktItemName">---</strong>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-muted small d-block">Categoria</span>
                                        <span class="badge bg-secondary" id="tktCategory">---</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-muted small d-block">Valor Pago</span>
                                        <strong class="text-success" id="tktPrice">R$ 0,00</strong>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-muted small d-block">Data do Resgate</span>
                                        <span class="text-dark small" id="tktDate">--/--/----</span>
                                    </div>
                                    <div class="col-12">
                                        <div
                                            class="p-2 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-3 text-start">
                                            <span class="text-warning-emphasis small fw-bold d-block"><i
                                                    class="bi bi-geo-alt-fill me-1"></i>Local de Estocagem no
                                                Armazém</span>
                                            <strong class="text-dark fs-5" id="tktStorage">---</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light p-3 border-0">
                        <button type="button" class="btn btn-secondary w-100 fw-bold rounded-3"
                            data-bs-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="/js/historico.js" defer></script>
</body>

</html>